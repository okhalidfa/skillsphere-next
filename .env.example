# =====================================================
# SkillSphere — Environment Variables
# Copy this file to .env.local and fill in your own values.
# Never commit your real .env.local file.
# =====================================================

# The base URL of your app (used for fetching local JSON data on the server)
# Local dev:           http://localhost:3000
# Production (Vercel): https://your-app.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# MongoDB connection string (Better Auth storage)
# Get one for free from MongoDB Atlas: https://www.mongodb.com/atlas
MONGODB_URL=your_mongodb_connection_string

# Better Auth
# Generate a random secret, e.g. `openssl rand -base64 32`
BETTER_AUTH_SECRET=your_random_secret_string
BETTER_AUTH_URL=http://localhost:3000

# Exposed to the browser so the client auth instance knows where to call.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (for "Continue with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
